---
import { ClientRouter } from "astro:transitions";
import "../styles/global.css";

const {
  title = "Default Title",
  description = "Default description",
  image = "/og-default.jpg",
} = Astro.props;
---

<html lang="en">
  <head>
    <script is:inline>
      (() => {
        const theme = localStorage.getItem("theme") || "dark";

        if (theme === "dark") {
          document.documentElement.classList.add("dark");
        }
      })();
    </script>
    <script is:inline>
      function applyTheme() {
        const theme = localStorage.getItem("theme") || "dark";

        document.documentElement.classList.toggle("dark", theme === "dark");

        const controller = document.querySelector("#theme-controller");

        if (controller) {
          controller.checked = theme === "light";
        }
      }

      function initThemeToggle() {
        const controller = document.querySelector("#theme-controller");

        if (!controller || controller.dataset.initialized) return;

        controller.dataset.initialized = "true";

        controller.addEventListener("change", () => {
          const theme = controller.checked ? "light" : "dark";

          localStorage.setItem("theme", theme);

          applyTheme();
        });
      }

      document.addEventListener("astro:page-load", () => {
        applyTheme();
        initThemeToggle();
      });
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:type" content="website" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    <!-- Theme init -->

    <ClientRouter />
  </head>

  <body class="bg-lightGray text-black">
    <slot />
  </body>
</html>
