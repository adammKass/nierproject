---
import { Image } from "astro:assets";
import { WEB_LINKS } from "../../constants";
import Layout from "../../layouts/Layout.astro";
import WebProjects from "../../components/WebProjects";
---

<Layout
  title="Web Design"
  description="Explore my web design projects, showcasing modern, clean, and professional websites that combine hand-painted artwork and 3D elements with contemporary web design."
>
  <main class="main">
    <div class="content">
      <h1 class="headingMain">Web Design</h1>
      <WebProjects projects={WEB_LINKS} client:load />
    </div>
  </main>
</Layout>
